<launch>
        <!-- dataset: euroc
            sequence: MH_01_easy MH_02_easy MH_03_medium MH_04_difficult MH_05_difficult 
                V1_01_easy V1_02_medium V1_03_difficult V2_01_easy V2_02_medium V2_03_difficult
        -->
        <!-- dataset: tumvi
            sequence: corridor1_512_16 corridor2_512_16 corridor3_512_16 corridor4_512_16 corridor5_512_16
                magistrale1_512_16 magistrale2_512_16 magistrale3_512_16 magistrale4_512_16 magistrale5_512_16 magistrale6_512_16 
        -->
        <!-- dataset: kaist
            sequence: circle circle_fast circle_head infinite infinite_fast
                infinite_head rotation rotation_fast square square_fast square_head 
        -->
    <arg name="dataset" default = "euroc" />
	<arg name="sequence" default = "V2_03_difficult" />
    
    <node name="benchmark_publisher" pkg="benchmark" type="benchmark_publisher_node" output="log" >
        <param name="sequence_path" type="string" value="$(find benchmark)/datasets/$(arg dataset)/$(arg sequence).txt" />
        <remap from="~estimated_odometry" to="/aplvio/odometry" />
        <!-- <remap from="~estimated_odometry" to="/vins_estimator/odometry" /> -->
        <!-- <remap from="~estimated_odometry" to="/lfvins_estimator/odometry" /> -->
    </node>
</launch>
